# ─────────────────────────────────────────────────────────────────────────────
# .streamlit/secrets.toml — LOCAL DEVELOPMENT ONLY
# Copy this file to .streamlit/secrets.toml and fill in your values.
# NEVER commit secrets.toml to git (it is already in .gitignore).
# For production (Render / Railway / Streamlit Cloud), set these as
# Environment Variables — do NOT deploy this file.
# ─────────────────────────────────────────────────────────────────────────────

# ── Supabase ─────────────────────────────────────────────────────────────────
# Find these in: supabase.com → your project → Settings → API
SUPABASE_URL = "https://YOUR_PROJECT_REF.supabase.co"
SUPABASE_KEY = "eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."   # anon/public key

# ── Stripe ───────────────────────────────────────────────────────────────────
# Find these in: dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY = "sk_test_..."   # use sk_live_... in production

# ── Stripe Price IDs ─────────────────────────────────────────────────────────
# Create products in Stripe → copy the price_xxx IDs here
# Starter plan  (e.g. $29/mo, 25 employees)
STRIPE_PRICE_STARTER  = "price_..."
# Pro plan      (e.g. $79/mo, 100 employees)
STRIPE_PRICE_PRO      = "price_..."
# Business plan (e.g. $199/mo, unlimited employees)
STRIPE_PRICE_BUSINESS = "price_..."

# ── Optional: Admin bypass emails ────────────────────────────────────────────
# Comma-separated list of emails that skip the subscription check entirely.
# Useful for your own account during development.
ADMIN_EMAILS = "you@yourcompany.com"
